+def _weighted_text_width(text: str, font_size_pt: float) -> float:
+    units = 0.0
+    for char in text:
+        if char.isspace():
+            units += 0.30
+        elif re.match(r"[\u3400-\u9fff]", char):
+            units += 1.0
+        elif char.isalnum():
+            units += 0.56
+        else:
+            units += 0.45
+    return units * font_size_pt
+
